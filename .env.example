# Neon Postgres SQLAlchemy URL (e.g. postgresql+psycopg://user:pass@host/dbname)
NEON_DATABASE_URL=

# Upstash QStash base URL (e.g. https://qstash.upstash.io)
UPSTASH_QSTASH_URL=

# Upstash QStash token
UPSTASH_QSTASH_TOKEN=

# Upstash QStash current signing key (for signature verification)
UPSTASH_QSTASH_CURRENT_SIGNING_KEY=

# Upstash Redis REST URL (e.g. https://<region>-<id>.upstash.io)
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST bearer token
UPSTASH_REDIS_REST_TOKEN=

# JWT access token signing secret (long random string)
JWT_SECRET=

# JWT refresh token signing secret (long random string)
JWT_REFRESH_SECRET=

# HTTP server port (e.g. 8000)
PORT=8000

# Runtime environment name (e.g. development, staging, production)
ENVIRONMENT=development

# Allowed CORS origin (e.g. http://localhost:3000)
CORS_ORIGIN=http://localhost:3000
